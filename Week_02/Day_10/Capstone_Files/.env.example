# Copy to `.env` (`Copy-Item .env.example .env`) and tweak as needed.
# Defaults work for the canned demo.

COMPOSE_PROJECT_NAME=day10capstone

# --- Postgres (config / reference tables, watched by Debezium) ---
CONFIG_PG_USER=postgres
CONFIG_PG_PASSWORD=postgres
CONFIG_PG_DB=config
CONFIG_PG_PORT=5433

# --- Postgres (airflow metadata) ---
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=airflow
AIRFLOW_PG_DB=airflow

# --- Kafka / Schema Registry ---
KAFKA_INTERNAL=kafka:29092
KAFKA_EXTERNAL_PORT=9092
SCHEMA_REGISTRY_URL_INTERNAL=http://schema-registry:8081
SCHEMA_REGISTRY_PORT=8081
KAFKA_CONNECT_PORT=8083
KAFKA_UI_PORT=8088

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_INTERNAL=http://minio:9000
BRONZE_BUCKET=bronze
SILVER_BUCKET=silver
GOLD_BUCKET=gold

# --- Airflow ---
AIRFLOW_WEB_PORT=8080
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_UID=50000

# --- Apache Hop ---
HOP_WEB_PORT=8089
HOP_PROJECT_HOME=/files/project

# --- Dashboards ---
QUALITY_DASHBOARD_PORT=5001
BUSINESS_DASHBOARD_PORT=5002
LIVE_MAP_DASHBOARD_PORT=5003

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ALERTMANAGER_PORT=9093

# --- Ingestor tuning ---
# ----------------------------------------------------------------------------
# DEMO CITY — everything (OGN filter, NOAA station list, map centre, seismic
# bbox) is scoped to a single city to keep volumes tiny for the lab.
# Default = Denver / Boulder, CO (real glider activity + NOAA coverage).
#
# To swap city, change these 5 vars and re-bootstrap. Suggested presets:
#   Denver/Boulder, CO (default):
#       CITY_NAME=Denver  CITY_LAT=39.74  CITY_LON=-104.99  CITY_RADIUS_KM=250
#       NOAA_STATIONS=KDEN,KBJC,KAPA,KCOS,KFNL,KGJT
#   New York, NY:
#       CITY_NAME=NewYork CITY_LAT=40.71  CITY_LON=-74.01   CITY_RADIUS_KM=200
#       NOAA_STATIONS=KJFK,KLGA,KEWR,KTEB,KHPN,KISP
#   Reno/Minden, NV (heavy glider traffic):
#       CITY_NAME=Reno    CITY_LAT=39.10  CITY_LON=-119.78  CITY_RADIUS_KM=250
#       NOAA_STATIONS=KRNO,KMEV,KCXP,KSPK
# ----------------------------------------------------------------------------
CITY_NAME=Denver
CITY_LAT=39.74
CITY_LON=-104.99
CITY_RADIUS_KM=250

# OGN (Open Glider Network) — APRS-IS server-side filter built from CITY_*.
OGN_APRS_USER=N0CALL
OGN_APRS_FILTER=r/${CITY_LAT}/${CITY_LON}/${CITY_RADIUS_KM}

# NOAA api.weather.gov (US only). Keep this list small — the ingestor polls
# each station every NOAA_POLL_SEC and api.weather.gov is rate-limited.
NOAA_POLL_SEC=120
NOAA_STATIONS=KDEN,KBJC,KAPA,KCOS,KFNL,KGJT
NOAA_USER_AGENT=(day10-capstone, ops@example.org)

# EMSC Seismic Portal — websocket is global; the dashboard highlights events
# within the city radius using CITY_LAT/CITY_LON/CITY_RADIUS_KM.
SEISMIC_WS_URL=wss://www.seismicportal.eu/standing_order/websocket

# Live map dashboard caps (prevent runaway memory on busy regions)
LIVEMAP_MAX_AIRCRAFT=100
LIVEMAP_MAX_TRAIL=40
LIVEMAP_MAX_QUAKES=300
LIVEMAP_AIRCRAFT_TTL_SEC=600
