<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>03_write_customers_postgres</name>
    <description>Write cleaned customers to PostgreSQL.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <created_user>-</created_user>
    <created_date>2026/06/05</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/05</modified_date>
    <key_for_session_key>UUID</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order>
    <hop><from>Read Clean Customers</from><to>Write Customers Table</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Read Clean Customers</name>
    <type>CsvInput</type>
    <description>Read the output from 01_clean_customers.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/output/customers_cleaned.csv</filename>
    <has_header>Y</has_header>
    <has_no_empty_lines>Y</has_no_empty_lines>
    <delimiter>,</delimiter>
    <enclosure>"</enclosure>
    <fields>
      <field><name>customer_id</name><type>Integer</type><format/><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>name</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>email</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>phone</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>country</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>order_amount</name><type>Number</type><format>0.00</format><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>2</precision><trim_type>both</trim_type></field>
      <field><name>customer_name</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>email_clean</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>country_normalized</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>phone_normalized</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>processed_at</name><type>Date</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>duplicate_count</name><type>Integer</type><format/><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>0</precision><trim_type>both</trim_type></field>
    </fields>
  </transform>
  <transform>
    <name>Write Customers Table</name>
    <type>TableOutput</type>
    <description>Insert cleaned customers into PostgreSQL.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>PostgreSQL_Medallion</connection>
    <schema>public</schema>
    <table>customers_cleaned</table>
    <commit_size>1000</commit_size>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <fields>
      <field><column_name>customer_id</column_name><stream_name>customer_id</stream_name></field>
      <field><column_name>customer_name</column_name><stream_name>customer_name</stream_name></field>
      <field><column_name>email</column_name><stream_name>email_clean</stream_name></field>
      <field><column_name>phone_normalized</column_name><stream_name>phone_normalized</stream_name></field>
      <field><column_name>country</column_name><stream_name>country_normalized</stream_name></field>
      <field><column_name>order_amount</column_name><stream_name>order_amount</stream_name></field>
      <field><column_name>duplicate_count</column_name><stream_name>duplicate_count</stream_name></field>
      <field><column_name>processed_at</column_name><stream_name>processed_at</stream_name></field>
    </fields>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
