<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>04_read_customers_postgres</name>
    <description>Read cleaned customers from PostgreSQL and write a verification CSV.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <created_user>-</created_user>
    <created_date>2026/06/05</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/05</modified_date>
    <key_for_session_key>UUID</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order>
    <hop><from>Read PostgreSQL Customers</from><to>Database Read CSV</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Read PostgreSQL Customers</name>
    <type>TableInput</type>
    <description>Query cleaned customers loaded by 03_write_customers_postgres.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>PostgreSQL_Medallion</connection>
    <sql>SELECT customer_id, customer_name, email, phone_normalized, country, order_amount, duplicate_count, processed_at FROM customers_cleaned WHERE country = 'DE' ORDER BY customer_id</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
  </transform>
  <transform>
    <name>Database Read CSV</name>
    <type>TextFileOutput</type>
    <description>Write database read result.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <file_name_base>${PROJECT_HOME}/output/postgres_customers_de</file_name_base>
    <file_name_extension>csv</file_name_extension>
    <add_to_result_filenames>Y</add_to_result_filenames>
    <create_parent_folder>Y</create_parent_folder>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
