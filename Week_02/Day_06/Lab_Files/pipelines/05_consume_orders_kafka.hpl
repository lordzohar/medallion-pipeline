<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>05_consume_orders_kafka</name>
    <description>Consume Kafka CDC events and run the batch processing sub-pipeline.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <created_user>-</created_user>
    <created_date>2026/06/05</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/05</modified_date>
    <key_for_session_key>UUID</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order/>
  <transform>
    <name>Consume orders.cdc</name>
    <type>KafkaConsumer</type>
    <description>Consume orders.cdc from Kafka and pass each batch to 06_kafka_order_batch_subpipeline.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <keyField>
      <kafkaName>key</kafkaName>
      <outputName>message_key</outputName>
      <outputType>String</outputType>
    </keyField>
    <messageField>
      <kafkaName>message</kafkaName>
      <outputName>message</outputName>
      <outputType>String</outputType>
    </messageField>
    <topicField>
      <kafkaName>topic</kafkaName>
      <outputName>topic</outputName>
      <outputType>String</outputType>
    </topicField>
    <offsetField>
      <kafkaName>offset</kafkaName>
      <outputName>offset</outputName>
      <outputType>Integer</outputType>
    </offsetField>
    <partitionField>
      <kafkaName>partition</kafkaName>
      <outputName>partition</outputName>
      <outputType>Integer</outputType>
    </partitionField>
    <timestampField>
      <kafkaName>timestamp</kafkaName>
      <outputName>kafka_timestamp</outputName>
      <outputType>Integer</outputType>
    </timestampField>
    <pipelinePath>${PROJECT_HOME}/pipelines/06_kafka_order_batch_subpipeline.hpl</pipelinePath>
    <batchSize>10</batchSize>
    <batchDuration>5000</batchDuration>
    <subTransform>Kafka Batch Rows</subTransform>
    <directBootstrapServers>kafka:29092</directBootstrapServers>
    <topic>orders.cdc</topic>
    <consumerGroup>day6-hop-lab</consumerGroup>
    <AUTO_COMMIT>N</AUTO_COMMIT>
    <options>
      <option><property>auto.offset.reset</property><value>earliest</value></option>
    </options>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
