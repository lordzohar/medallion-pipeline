<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>00_first_pipeline_csv_to_csv</name>
    <description>First Apache Hop pipeline: read a source CSV and write a new CSV target.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <created_user>-</created_user>
    <created_date>2026/06/05</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/05</modified_date>
    <key_for_session_key>UUID</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order>
    <hop><from>CSV file input</from><to>Text file output</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>CSV file input</name>
    <type>CsvInput</type>
    <description>Read the simple source file used in the first-pipeline walkthrough.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/first_pipeline_source.csv</filename>
    <has_header>Y</has_header>
    <has_no_empty_lines>Y</has_no_empty_lines>
    <delimiter>,</delimiter>
    <enclosure>"</enclosure>
    <escape_char/>
    <fields>
      <field><name>customer_id</name><type>Integer</type><format/><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>customer_name</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>city</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
  </transform>
  <transform>
    <name>Text file output</name>
    <type>TextFileOutput</type>
    <description>Write the copied CSV file.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <fileNameInField>N</fileNameInField>
    <file_name_base>${PROJECT_HOME}/output/first_pipeline_result</file_name_base>
    <file_name_extension>csv</file_name_extension>
    <add_date>N</add_date>
    <add_time>N</add_time>
    <SpecifyFormat>N</SpecifyFormat>
    <add_to_result_filenames>Y</add_to_result_filenames>
    <create_parent_folder>Y</create_parent_folder>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
