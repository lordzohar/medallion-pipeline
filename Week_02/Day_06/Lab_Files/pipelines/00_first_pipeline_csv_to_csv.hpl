<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <pipeline_version/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters/>
    <name>00_first_pipeline_csv_to_csv</name>
    <name_sync_with_filename>N</name_sync_with_filename>
    <description>First Apache Hop pipeline: read a source CSV and write a new CSV target.</description>
    <extended_description/>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/08 05:08:33.629</created_date>
    <modified_date>2026/06/08 05:08:33.629</modified_date>
  </info>
  <transform>
    <type>CsvInput</type>
    <name>CSV file input</name>
    <filename>${PROJECT_HOME}/data/first_pipeline_source.csv</filename>
    <filename_field/>
    <include_filename>N</include_filename>
    <rownum_field/>
    <header>Y</header>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>Y</add_filename_result>
    <parallel>N</parallel>
    <encoding>UTF-8</encoding>
    <newline_possible>N</newline_possible>
    <ignoreFields>N</ignoreFields>
    <fields>
      <field>
        <name>customer_id</name>
        <length>-1</length>
        <type>Integer</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>0</precision>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>customer_name</name>
        <length>-1</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
      </field>
      <field>
        <name>city</name>
        <length>-1</length>
        <type>String</type>
        <format/>
        <trim_type>both</trim_type>
        <precision>-1</precision>
        <currency/>
        <decimal/>
        <group/>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>120</xloc>
      <yloc>180</yloc>
    </GUI>
    <description>Read the simple source file used in the first-pipeline walkthrough.</description>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TextFileOutput</type>
    <name>Text file output</name>
    <compression>None</compression>
    <create_parent_folder>Y</create_parent_folder>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <ignore_fields>N</ignore_fields>
    <file>
      <name>${PROJECT_HOME}/output/first_pipeline_result</name>
      <do_not_open_new_file_init>N</do_not_open_new_file_init>
      <extension>csv</extension>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>420</xloc>
      <yloc>180</yloc>
    </GUI>
    <description>Write the copied CSV file.</description>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>CSV file input</from>
      <to>Text file output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
