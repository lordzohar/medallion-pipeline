<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>02_enrich_orders</name>
    <description>Lookup product data, normalize categories, and calculate order metrics.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <created_user>-</created_user>
    <created_date>2026/06/05</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/05</modified_date>
    <key_for_session_key>UUID</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order>
    <hop><from>Read Orders</from><to>Lookup Product</to><enabled>Y</enabled></hop>
    <hop><from>Read Products</from><to>Lookup Product</to><enabled>Y</enabled></hop>
    <hop><from>Lookup Product</from><to>Calculate Order Metrics</to><enabled>Y</enabled></hop>
    <hop><from>Calculate Order Metrics</from><to>Orders Enriched CSV</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Read Orders</name>
    <type>CsvInput</type>
    <description>Read order fact data.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/orders.csv</filename>
    <has_header>Y</has_header>
    <has_no_empty_lines>Y</has_no_empty_lines>
    <delimiter>,</delimiter>
    <enclosure>"</enclosure>
    <fields>
      <field><name>order_id</name><type>Integer</type><format/><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>customer_id</name><type>Integer</type><format/><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>product_id</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>status</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>amount</name><type>Number</type><format>0.00</format><currency/><decimal_symbol>.</decimal_symbol><group_symbol>,</group_symbol><length>-1</length><precision>2</precision><trim_type>both</trim_type></field>
    </fields>
  </transform>
  <transform>
    <name>Read Products</name>
    <type>CsvInput</type>
    <description>Read product lookup data.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/products.csv</filename>
    <has_header>Y</has_header>
    <has_no_empty_lines>Y</has_no_empty_lines>
    <delimiter>,</delimiter>
    <enclosure>"</enclosure>
    <fields>
      <field><name>product_id</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>product_name</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>category</name><type>String</type><format/><currency/><decimal_symbol/><group_symbol/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
  </transform>
  <transform>
    <name>Lookup Product</name>
    <type>StreamLookup</type>
    <description>Lookup product_name and category by product_id.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read Products</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key><name>product_id</name><field>product_id</field></key>
      <value><name>product_name</name><rename>product_name</rename><default>UNKNOWN</default><type>String</type></value>
      <value><name>category</name><rename>category</rename><default>UNKNOWN</default><type>String</type></value>
    </lookup>
  </transform>
  <transform>
    <name>Calculate Order Metrics</name>
    <type>ScriptValueMod</type>
    <description>Normalize category and calculate tax, discount, and net amount.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Calculate</jsScript_name>
        <jsScript_script><![CDATA[
var product_category = category == null ? "UNKNOWN" : String(category).trim().toUpperCase();
var amount_with_tax = amount * 1.10;
var discount_amount = amount >= 100 ? amount * 0.05 : 0;
var net_amount = amount_with_tax - discount_amount;
var processed_at = new Date();
        ]]></jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>product_category</name><rename>product_category</rename><type>String</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
      <field><name>amount_with_tax</name><rename>amount_with_tax</rename><type>Number</type><length>-1</length><precision>2</precision><replace>N</replace></field>
      <field><name>discount_amount</name><rename>discount_amount</rename><type>Number</type><length>-1</length><precision>2</precision><replace>N</replace></field>
      <field><name>net_amount</name><rename>net_amount</rename><type>Number</type><length>-1</length><precision>2</precision><replace>N</replace></field>
      <field><name>processed_at</name><rename>processed_at</rename><type>Date</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
    </fields>
  </transform>
  <transform>
    <name>Orders Enriched CSV</name>
    <type>TextFileOutput</type>
    <description>Write enriched orders.</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <file_name_base>${PROJECT_HOME}/output/orders_enriched</file_name_base>
    <file_name_extension>csv</file_name_extension>
    <add_to_result_filenames>Y</add_to_result_filenames>
    <create_parent_folder>Y</create_parent_folder>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
